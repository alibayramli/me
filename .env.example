# Grafana Faro runtime config.
# These values are embedded into the browser bundle, so treat them as public app config.
VITE_FARO_ENABLED=true
VITE_FARO_URL=
VITE_FARO_APP_NAME=ali-bayramli-portfolio
VITE_FARO_APP_ENV=production

# Grafana source map upload config.
# Keep the API key private and only provide it in CI or local build env.
# Local builds only upload when FARO_UPLOAD_SOURCEMAPS=true is set explicitly.
FARO_APP_ID=
FARO_STACK_ID=
FARO_SOURCEMAP_ENDPOINT=
FARO_SOURCEMAP_API_KEY=
FARO_SOURCEMAP_PREFIX_PATH=me/
FARO_UPLOAD_SOURCEMAPS=false
